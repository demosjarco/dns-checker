{
	"type": "module",
	"scripts": {
		"build": "qwik build",
		"build.client": "vite build",
		"build.preview": "vite build --ssr src/entry.preview.tsx",
		"build.server": "vite build -c adapters/static/vite.config.ts",
		"build.types:cf": "wrangler types",
		"postbuild.types:cf": "prettier --write worker-configuration.d.ts",
		"build.types:tsc": "tsc --noEmit",
		"build.types": "npm run build.types:cf && npm run build.types:tsc",
		"build:db": "drizzle-kit generate --dialect=sqlite --driver=d1-http --schema=\"db/index.ts\" --out=\"db\"",
		"postbuild:db": "prettier --write db",
		"fmt": "prettier --check .",
		"fmt:fix": "prettier --write .",
		"lint": "eslint **/*.*ts*",
		"lint:fix": "npm run lint -- --fix",
		"preview": "qwik build preview && vite preview --open",
		"preview:lhci": "qwik build preview && vite preview --port 8080",
		"preclean": "npx -y rimraf@latest --glob ./**/.wrangler ./**/*.tsbuildinfo",
		"clean": "npx -y rimraf@latest --glob \"./dist/!(api)\" \"./dist/.[!.]*\" \"./dist/..?*\" ./server ./tmp",
		"dev": "node --inspect ./node_modules/vite/bin/vite.js --mode ssr --force",
		"start:clean": "npm run clean && npm run start",
		"start": "wrangler dev --test-scheduled --live-reload true",
		"deploy:db": "wrangler d1 migrations apply PROBE_DB --remote",
		"qwik": "qwik",
		"build:static": "tsx staticApi.mts",
		"publish:static": "tsx apiGateway.mts"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/demosjarco/dns-checker.git"
	},
	"author": "DemosJarco <1209494+demosjarco@users.noreply.github.com>",
	"license": "MIT",
	"private": true,
	"bugs": {
		"url": "https://github.com/demosjarco/dns-checker/issues"
	},
	"homepage": "https://github.com/demosjarco/dns-checker#readme",
	"engines": {
		"node": "^18.17.0 || ^20.3.0 || >=21.0.0"
	},
	"engines-annotation": "Mostly required by sharp which needs a Node-API v9 compatible runtime",
	"dependencies": {
		"@hono/zod-openapi": "1.4.0",
		"@types/dns-packet": "5.6.5",
		"cloudflare": "6.3.0",
		"dns-packet": "5.6.1",
		"drizzle-orm": "1.0.0-rc.3",
		"hono": "4.12.26",
		"iata-location": "1.0.1",
		"leaflet": "1.9.4",
		"uuid": "14.0.0",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@builder.io/qwik": "1.20.0",
		"@builder.io/qwik-city": "1.20.0",
		"@demosjarco/prettier-config": "1.0.2",
		"@eslint/js": "10.0.1",
		"@rollup/plugin-node-resolve": "16.0.3",
		"@scalar/openapi-to-markdown": "0.5.19",
		"@tailwindcss/vite": "4.3.0",
		"@types/leaflet": "1.9.21",
		"@types/node": "25.9.1",
		"drizzle-kit": "1.0.0-rc.3",
		"eslint": "10.4.0",
		"eslint-config-prettier": "10.1.8",
		"eslint-plugin-qwik": "1.20.0",
		"flowbite": "4.0.2",
		"prettier": "3.8.3",
		"prettier-plugin-tailwindcss": "0.8.0",
		"tailwindcss": "4.3.0",
		"tsx": "4.22.3",
		"turnstile-types": "1.2.3",
		"typescript": "6.0.3",
		"typescript-eslint": "8.59.4",
		"vite-tsconfig-paths": "6.1.1",
		"wrangler": "4.94.0",
		"zaraz-ts": "1.2.0"
	}
}
